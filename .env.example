# =====================================================================
# Variables d'environnement requises par le backend Elisabeth Constantin.
# Ne pas commiter de vraies valeurs — copier vers `.env` localement.
# =====================================================================

# --- Auth admin (legacy cookie HMAC, sera remplacé par Keycloak en Lot 3) ---
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password

# Clé HMAC du cookie de session admin (auth_admin.py).
# Distincte de JWT_SECRET ci-dessous (utilisé par la newsletter).
SECRET_KEY=change_me_min_32_chars_for_admin_cookie_signing

# Durée de session admin (heures)
SESSION_DURATION_HOURS=2

# --- URLs publiques ---
# Plusieurs origines possibles séparées par des virgules. "*" interdit credentials.
FRONTEND_URL=http://localhost:8080
BACKEND_URL=http://localhost:8000

# --- MongoDB (Atlas en prod, peut être local en dev) ---
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/
MONGO_DB=site_maman

# --- Stripe (côté serveur) ---
STRIPE_SECRET_KEY=sk_test_replace_me

# --- MailerLite (newsletter double opt-in) ---
MAILERLITE_PRIVATE_KEY=your_mailerlite_api_key_here
MAILERLITE_SENDER_EMAIL=newsletter@elisabeth-constantin.fr
MAILERLITE_SENDER_NAME=Elisabeth Constantin
MAILERLITE_NEWSLETTER_GROUP=newsletter_site
# Secret partagé pour valider la signature du webhook MailerLite (optionnel mais recommandé).
MAILERLITE_WEBHOOK_SECRET=

# JWT secret utilisé pour les tokens de confirmation/désinscription newsletter (min 32 caractères).
JWT_SECRET=your_very_long_random_secret_key_here_min_32_chars_please_change_me

# --- DeepL (traductions FR/EN, optionnel) ---
# Une seule des deux variables suffit, DEEPL_API_KEY a la priorité.
DEEPL_API_KEY=
DEEPL_AUTH_KEY=
# Plan : "free" ou "pro" (modifie l'URL par défaut). Laisser vide en prod si la clé suffit.
DEEPL_PLAN=
# Override explicite de l'URL DeepL (sinon dérivée du plan).
DEEPL_API_URL=
